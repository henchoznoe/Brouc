{
  "name": "brouc",
  "version": "1.0.1",
  "description": "TODO",
  "homepage": "https://github.com/henchoznoe/Brouc",
  "bugs": {
    "url": "https://github.com/henchoznoe/Brouc/issues",
    "email": "henchoznoe@gmail.com"
