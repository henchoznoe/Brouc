  "license": "MIT",
  "author": "Noé Henchoz <henchoznoe@gmail.com> (https://henchoznoe.ch/)",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henchoznoe/Brouc.git"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env.local server.ts",
    "dev:next": "next dev",
    "build": "prisma generate && prisma migrate deploy && tsx prisma/seed.ts && next build",
    "start": "node --env-file=.env --import tsx server.ts",
    "prepare": "lefthook install",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check --write .",
    "check:all": "biome check --write . && knip",
    "check:com": "biome check --write . && knip && vitest run && tsc --noEmit && next build",
    "knip": "knip",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "db:deploy": "prisma generate && prisma migrate deploy && tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@radix-ui/react-slot": "^1.2.4",
    "better-auth": "^1.6.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.75.0",
    "server-only": "^0.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.6",
    "dotenv": "^17.4.2",
    "knip": "^6.14.0",
    "lefthook": "^2.1.6",
    "postcss": "^8.5.14",
    "semantic-release": "^25.0.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "private": true
}
