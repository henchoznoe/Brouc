# ==============================================================================
# GENERAL APPLICATION SETTINGS
# ==============================================================================
NODE_ENV="development"

# ==============================================================================
# BETTER AUTH SETTINGS
# ==============================================================================
# Generate a random secret using `openssl rand -base64 32`
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL=""

# ==============================================================================
# OAUTH PROVIDERS
# ==============================================================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ==============================================================================
# DATABASE SETUP
# ==============================================================================
# Pooled for PrismaClient (port 6543 with pgBouncer and no SSL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/brouc"
# Direct for Prisma CLI (port 5432 without pgBouncer)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/brouc"

# ==============================================================================
# REDIS
# ==============================================================================
REDIS_URL="redis://localhost:6379"

# ==============================================================================
# SEED SETTINGS
# ==============================================================================
# Comma-separated list of admin emails (used by prisma/seed-admin.ts)
ADMIN_EMAILS=""

# ==============================================================================
# PUBLIC ENVIRONMENT VARIABLES
# ==============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
